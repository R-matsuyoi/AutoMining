# =============================================================================
# AutoMining 环境配置文件
# =============================================================================

# ---------------------------- 平台与系统 --------------------------------------
# 平台选择: 本机测试 | 亚信jupyter
PLAT=本机测试

# 操作系统类型: win | linux
SYS_TEM=win

# ---------------------------- 数据库配置 --------------------------------------
# 数据库类型: gp (PostgreSQL/Greenplum) | hive (Hive/Spark)
DB_TYPE=gp

# PostgreSQL/Greenplum 连接参数 (DB_TYPE=gp 时生效)
DB_NAME=postgres
DB_USER=postgres
DB_PWD=postgres
DB_PORT=
DB_HOST=

# 数据库表名前缀 (schema名称 + 点号)
DB_PREFIX=

# SQL 操作延时秒数 (避免部分数据库操作过快导致的问题)
DB_SECONDS=

# ---------------------------- 工作目录 ----------------------------------------
# 模型结果保存目录
MODELWD_PLATFORM=

# 个人工作目录 (代码上传、日志存储)
SELFWD_PLATFORM=

# ---------------------------- SQL 执行模式 ------------------------------------
# SQL 执行方式: execute (数据库直连执行) | print (仅打印SQL，手动粘贴执行)
SQL_TYPE=execute

# SQL 注释字符
SQL_COMMENT=----

# 数据读取来源: gp (数据库) | 其他 (文件)
SRC=gp

# ---------------------------- 模型训练参数 ------------------------------------
# 是否进行字段两两自动衍生 (加减乘除)
AUTO_PAIR2=false

# 统计近n月基础数据各账期分布差值阈值 (None 则不检查)
DIFF_LIMIT=None

# 是否计算结果宽表字段稳定度 (PSI)
TABLE_PSI=true

# 是否计算结果宽表字段间相关系数
TABLE_R=true

# ---------------------------- 预测阶段参数 ------------------------------------
# 匹配 Top-N 高分原因字段个数 (None 则不匹配)
N_REASON=

# 预测数据账期 (yyyymm)
M_P=

# ---------------------------- 日志配置 ----------------------------------------
# 日志类型: txt | pkl
LOG_TYPE=txt

# ---------------------------- 默认值替换字段 (上传至平台时使用) ---------------
# 以下用于 privy_replace_default / privy_upload_code 中替换代码字符串中的默认值
# 数据库名 (平台环境)
DEFAULT_DBNAME=None

# 数据库用户 (平台环境)
DEFAULT_USER=None

# 数据库密码 (平台环境)
DEFAULT_PWD=None

# 数据库端口 (平台环境)
DEFAULT_PORT=None

# 数据库主机 (平台环境)
DEFAULT_HOST=None
